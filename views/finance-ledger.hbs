<div class="max-w-6xl mx-auto space-y-8">
    <div class="flex justify-between items-center flex-wrap gap-4">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 tracking-tight">Financial Ledger & Budget</h2>
            <p class="text-gray-500 mt-1">Track all income, expenses, and budget targets for {{installation.name}}.</p>
        </div>
        <div class="flex flex-wrap gap-3">
            <form method="GET" action="/finance/ledger" class="flex gap-2 items-center">
                <input type="month" name="period" value="{{period}}" class="bg-white border border-gray-200 rounded-xl px-4 py-2.5 text-sm shadow-sm focus:ring-2 focus:ring-primary">
                <button type="submit" class="bg-white border border-gray-200 px-4 py-2.5 rounded-xl text-sm font-bold shadow-sm hover:bg-gray-50 transition">Filter</button>
            </form>
            <button onclick="document.getElementById('add-transaction-modal').classList.remove('hidden')" class="bg-primary text-white px-6 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">+ Add Transaction</button>
            <button onclick="document.getElementById('add-budget-modal').classList.remove('hidden')" class="bg-white border border-gray-200 text-primary px-6 py-3 rounded-xl font-bold shadow-sm hover:bg-gray-50 transition">Set Budget</button>
        </div>
    </div>

    {{#if success}}<div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-xl"><p class="text-sm text-green-700 font-bold">{{success}}</p></div>{{/if}}
    {{#if error}}<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-sm text-red-700 font-bold">{{error}}</p></div>{{/if}}

    <!-- Summary Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div class="bg-gradient-to-br from-emerald-500 to-teal-600 p-6 rounded-3xl text-white shadow-xl shadow-emerald-100">
            <p class="text-xs font-bold uppercase tracking-widest text-emerald-100">Total Income</p>
            <h3 class="text-3xl font-extrabold mt-3">₦{{totalIncome}}</h3>
        </div>
        <div class="bg-gradient-to-br from-rose-500 to-red-600 p-6 rounded-3xl text-white shadow-xl shadow-rose-100">
            <p class="text-xs font-bold uppercase tracking-widest text-rose-100">Total Expenditure</p>
            <h3 class="text-3xl font-extrabold mt-3">₦{{totalExpense}}</h3>
        </div>
        <div class="bg-gradient-to-br from-primary to-blue-800 p-6 rounded-3xl text-white shadow-xl shadow-blue-100">
            <p class="text-xs font-bold uppercase tracking-widest text-blue-200">Balance</p>
            <h3 class="text-3xl font-extrabold mt-3">₦{{balance}}</h3>
        </div>
    </div>

    <!-- Budget Tracker -->
    {{#if budgetReport}}
    <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-8 space-y-5">
        <h3 class="text-xl font-bold text-gray-900">Budget Tracker — {{period}}</h3>
        <div class="space-y-4">
            {{#each budgetReport}}
            <div class="space-y-2">
                <div class="flex justify-between items-center">
                    <span class="font-bold text-gray-700 text-sm">{{category}}</span>
                    <div class="flex items-center gap-3">
                        <span class="text-xs text-gray-500">₦{{spent}} / ₦{{amount}}</span>
                        {{#if overspent}}
                        <span class="px-2 py-0.5 bg-red-100 text-red-700 text-[10px] font-extrabold rounded-full uppercase">Over Budget!</span>
                        {{/if}}
                    </div>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2.5">
                    <div class="h-2.5 rounded-full {{#if overspent}}bg-red-500{{else}}bg-primary{{/if}}" style="width: {{#if overspent}}100{{else}}{{spent}}{{/if}}%; max-width: 100%"></div>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
    {{/if}}

    <!-- Transactions Table -->
    <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="p-8 border-b border-gray-50">
            <h3 class="text-xl font-bold">Transaction Ledger</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500 font-bold border-b border-gray-100">
                    <tr>
                        <th class="px-8 py-4">Date</th>
                        <th class="px-8 py-4">Type</th>
                        <th class="px-8 py-4">Category</th>
                        <th class="px-8 py-4">Description</th>
                        <th class="px-8 py-4 text-right">Amount</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    {{#each transactions}}
                    <tr class="hover:bg-gray-50/50 transition">
                        <td class="px-8 py-4 text-sm text-gray-600 font-medium">{{date}}</td>
                        <td class="px-8 py-4">
                            <span class="px-2.5 py-1 rounded-full text-[10px] font-extrabold uppercase tracking-wider
                                {{#if (eq type 'income')}}bg-emerald-100 text-emerald-700{{else}}bg-red-100 text-red-700{{/if}}">
                                {{type}}
                            </span>
                        </td>
                        <td class="px-8 py-4 text-sm font-bold text-gray-700">{{category}}</td>
                        <td class="px-8 py-4 text-sm text-gray-500">{{description}}</td>
                        <td class="px-8 py-4 text-right font-bold {{#if (eq type 'income')}}text-emerald-600{{else}}text-red-600{{/if}}">₦{{amount}}</td>
                    </tr>
                    {{else}}
                    <tr><td colspan="5" class="px-8 py-10 text-center text-gray-500">No transactions recorded yet.</td></tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Add Transaction Modal -->
    <div id="add-transaction-modal" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-xl font-bold">Record Transaction</h3>
                <button type="button" onclick="document.getElementById('add-transaction-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/finance/ledger/transaction" method="POST" class="p-8 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Type *</label>
                        <select name="type" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                            <option value="income">Income</option>
                            <option value="expense">Expense</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Category *</label>
                        <input type="text" name="category" required placeholder="e.g. Tithes, Utilities" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Amount (₦) *</label>
                        <input type="number" step="0.01" name="amount" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Date *</label>
                        <input type="date" name="date" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                    </div>
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Description / Notes</label>
                    <textarea name="description" rows="2" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm"></textarea>
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" onclick="document.getElementById('add-transaction-modal').classList.add('hidden')" class="px-6 py-3 font-bold text-gray-500">Cancel</button>
                    <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Save Transaction</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Set Budget Modal -->
    <div id="add-budget-modal" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-xl font-bold">Set Budget Target</h3>
                <button type="button" onclick="document.getElementById('add-budget-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/finance/ledger/budget" method="POST" class="p-8 space-y-4">
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Expense Category *</label>
                    <input type="text" name="category" required placeholder="e.g. Utilities, Welfare" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Budget Amount (₦) *</label>
                    <input type="number" step="0.01" name="amount" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Period (YYYY-MM) *</label>
                    <input type="month" name="period" value="{{period}}" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" onclick="document.getElementById('add-budget-modal').classList.add('hidden')" class="px-6 py-3 font-bold text-gray-500">Cancel</button>
                    <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Save Budget</button>
                </div>
            </form>
        </div>
    </div>
</div>
