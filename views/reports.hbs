<div class="max-w-6xl mx-auto space-y-8">
    <div class="flex justify-between items-center flex-wrap gap-4">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 tracking-tight">Weekly Reports</h2>
            <p class="text-gray-500 mt-1">Submit, approve, and track branch reports through the approval workflow.</p>
        </div>
        {{#if canSubmit}}
        <button onclick="document.getElementById('create-report-modal').classList.remove('hidden')" class="bg-primary text-white px-6 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">+ New Report Draft</button>
        {{/if}}
    </div>

    {{#if success}}<div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-xl"><p class="text-sm text-green-700 font-bold">{{success}}</p></div>{{/if}}
    {{#if error}}<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-sm text-red-700 font-bold">{{error}}</p></div>{{/if}}

    <!-- Report Pipeline States Legend -->
    <div class="flex flex-wrap gap-2 text-[10px] font-bold uppercase tracking-wider">
        <span class="px-3 py-1.5 bg-slate-100 text-slate-600 rounded-full">Draft</span>
        <span class="text-gray-300 font-light">→</span>
        <span class="px-3 py-1.5 bg-amber-100 text-amber-700 rounded-full">Submitted</span>
        <span class="text-gray-300 font-light">→</span>
        <span class="px-3 py-1.5 bg-emerald-100 text-emerald-700 rounded-full">Approved</span>
        <span class="text-gray-300 font-light">→</span>
        <span class="px-3 py-1.5 bg-indigo-100 text-indigo-700 rounded-full">HQ Reviewed</span>
        <span class="text-gray-300 font-light mx-1">|</span>
        <span class="px-3 py-1.5 bg-red-100 text-red-700 rounded-full">Rejected</span>
    </div>

    <!-- Reports List -->
    <div class="space-y-4">
        {{#each reports}}
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm p-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div class="space-y-2 flex-1">
                <div class="flex items-center gap-3 flex-wrap">
                    <h3 class="text-base font-bold text-gray-900">{{period}} — Week {{weekNumber}}</h3>
                    {{#if isLate}}<span class="px-2 py-0.5 bg-orange-100 text-orange-700 text-[10px] font-extrabold rounded-full uppercase tracking-wider">⚠ Late</span>{{/if}}
                    <span class="px-2.5 py-1 rounded-full text-[10px] font-extrabold uppercase tracking-wider
                        {{#if (eq status 'draft')}}bg-slate-100 text-slate-700{{/if}}
                        {{#if (eq status 'submitted')}}bg-amber-100 text-amber-700{{/if}}
                        {{#if (eq status 'approved')}}bg-emerald-100 text-emerald-700{{/if}}
                        {{#if (eq status 'rejected')}}bg-red-100 text-red-700{{/if}}
                        {{#if (eq status 'hq_reviewed')}}bg-indigo-100 text-indigo-700{{/if}}">
                        {{status}}
                    </span>
                </div>
                {{#if notes}}<p class="text-sm text-gray-500">{{notes}}</p>{{/if}}
                {{#if rejectionReason}}<p class="text-sm text-red-600 font-bold">Rejection reason: "{{rejectionReason}}"</p>{{/if}}
                <div class="flex gap-4 text-xs text-gray-400 font-medium flex-wrap">
                    {{#if SubmittedBy}}<span>Submitted by <strong class="text-gray-600">{{SubmittedBy.fullName}}</strong></span>{{/if}}
                    {{#if ApprovedBy}}<span>| Approved by <strong class="text-gray-600">{{ApprovedBy.fullName}}</strong></span>{{/if}}
                </div>
            </div>
            <div class="flex gap-2 flex-wrap">
                {{#if (eq status 'draft')}}
                    <form action="/reports/{{id}}/submit" method="POST" class="inline">
                        <button type="submit" class="bg-primary text-white text-xs px-4 py-2 rounded-xl font-bold shadow-sm hover:opacity-90 transition">Submit for Approval</button>
                    </form>
                {{/if}}
                {{#if canApprove}}
                    {{#if (eq status 'submitted')}}
                    <form action="/reports/{{id}}/approve" method="POST" class="inline">
                        <button type="submit" class="bg-emerald-600 text-white text-xs px-4 py-2 rounded-xl font-bold hover:bg-emerald-700 transition">Approve</button>
                    </form>
                    <button onclick="openRejectModal('{{id}}')" class="bg-white border text-red-600 text-xs px-4 py-2 rounded-xl font-bold hover:bg-red-50 transition">Reject</button>
                    {{/if}}
                {{/if}}
            </div>
        </div>
        {{else}}
        <div class="bg-white rounded-3xl border border-gray-100 p-12 text-center text-gray-500">No reports found. Create a draft to get started.</div>
        {{/each}}
    </div>

    <!-- Create Report Modal -->
    <div id="create-report-modal" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-xl font-bold">Create Report Draft</h3>
                <button type="button" onclick="document.getElementById('create-report-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/reports/create" method="POST" class="p-8 space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Period (YYYY-MM) *</label>
                        <input type="month" name="period" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Week Number *</label>
                        <select name="weekNumber" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                            <option value="1">Week 1</option>
                            <option value="2">Week 2</option>
                            <option value="3">Week 3</option>
                            <option value="4">Week 4</option>
                            <option value="5">Week 5</option>
                        </select>
                    </div>
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Notes / Summary</label>
                    <textarea name="notes" rows="3" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm" placeholder="Brief overview of this week's services..."></textarea>
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" onclick="document.getElementById('create-report-modal').classList.add('hidden')" class="px-6 py-3 font-bold text-gray-500">Cancel</button>
                    <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Create Draft</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Reject Modal -->
    <div id="reject-report-modal" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-xl font-bold text-red-600">Reject Report</h3>
                <button type="button" onclick="document.getElementById('reject-report-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form id="reject-report-form" action="" method="POST" class="p-8 space-y-4">
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Reason for Rejection *</label>
                    <textarea name="rejectionReason" rows="3" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-red-400 transition shadow-sm" placeholder="Please provide clear feedback..."></textarea>
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" onclick="document.getElementById('reject-report-modal').classList.add('hidden')" class="px-6 py-3 font-bold text-gray-500">Cancel</button>
                    <button type="submit" class="bg-red-600 text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:bg-red-700 transition">Reject Report</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openRejectModal(reportId) {
        document.getElementById('reject-report-form').action = `/reports/${reportId}/reject`;
        document.getElementById('reject-report-modal').classList.remove('hidden');
    }
</script>
