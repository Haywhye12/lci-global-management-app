<div class="max-w-6xl mx-auto space-y-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight">Library & Community Feed</h2>
            <p class="text-gray-500 mt-1">Access branch E-Books and read/write dynamic updates on the community bulletin feed.</p>
        </div>
        <!-- Tab Toggle buttons -->
        <div class="flex bg-gray-100 p-1.5 rounded-2xl self-start">
            <button onclick="switchTab('library-pane', 'feed-pane', this)" class="tab-btn px-5 py-2.5 rounded-xl text-sm font-bold text-gray-600 transition bg-white text-gray-900 shadow-sm">
                📚 Books Library
            </button>
            <button onclick="switchTab('feed-pane', 'library-pane', this)" class="tab-btn px-5 py-2.5 rounded-xl text-sm font-bold text-gray-600 transition">
                💬 Branch Bulletin Feed
            </button>
        </div>
    </div>

    {{#if success}}
    <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-xl shadow-sm">
        <p class="text-sm text-green-700 font-bold">🎉 {{success}}</p>
    </div>
    {{/if}}
    {{#if error}}
    <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl shadow-sm">
        <p class="text-sm text-red-700 font-bold">⚠️ {{error}}</p>
    </div>
    {{/if}}

    <!-- ══════════════════ 1. BOOKS LIBRARY PANE ══════════════════ -->
    <div id="library-pane" class="space-y-8">
        {{#if isUploader}}
        <!-- Upload Form Collapse -->
        <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm space-y-6">
            <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-gray-900 flex items-center gap-2">
                    📥 Upload New Book (PDF)
                </h3>
                <span class="text-xs text-red-500 font-bold bg-red-50 px-3 py-1 rounded-full border border-red-100">
                    NB: Max PDF limit is 15MB
                </span>
            </div>
            <form action="/library/books/upload" method="POST" enctype="multipart/form-data" class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="space-y-2 md:col-span-1">
                    <label class="text-xs font-bold text-gray-700 ml-1">Book Title *</label>
                    <input type="text" name="title" required placeholder="e.g. The Art of Leadership" 
                           class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition text-sm">
                </div>
                <div class="space-y-2 md:col-span-1">
                    <label class="text-xs font-bold text-gray-700 ml-1">Author Name</label>
                    <input type="text" name="author" placeholder="e.g. Bishop Dag Heward-Mills" 
                           class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition text-sm">
                </div>
                <div class="space-y-2 md:col-span-1">
                    <label class="text-xs font-bold text-gray-700 ml-1">Scope Availability</label>
                    <select name="isGlobal" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition text-sm">
                        <option value="false">Only This Branch ({{installation.name}})</option>
                        <option value="true">Global (All branches can access)</option>
                    </select>
                </div>
                <div class="space-y-2 md:col-span-1">
                    <label class="text-xs font-bold text-gray-700 ml-1">PDF File *</label>
                    <input type="file" name="bookPdf" accept="application/pdf" required
                           class="w-full text-xs text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-extrabold file:bg-primary file:text-white hover:file:opacity-90 cursor-pointer">
                </div>
                <div class="space-y-2 md:col-span-1">
                    <label class="text-xs font-bold text-gray-700 ml-1">Cover Image (Optional)</label>
                    <input type="file" name="coverImage" accept="image/*"
                           class="w-full text-xs text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-extrabold file:bg-emerald-600 file:text-white hover:file:opacity-90 cursor-pointer">
                </div>
                <div class="space-y-2 md:col-span-1">
                    <label class="text-xs font-bold text-gray-700 ml-1">Description</label>
                    <input type="text" name="description" placeholder="Brief tagline or description..." 
                           class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition text-sm">
                </div>
                <div class="md:col-span-3 flex justify-end">
                    <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-95 transition text-sm">Publish Book</button>
                </div>
            </form>
        </div>
        {{/if}}

        <!-- Books Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {{#each books}}
            <div class="bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition duration-300 flex flex-col">
                <!-- Cover Image container -->
                <div class="h-48 bg-gray-100 relative">
                    <img src="{{this.coverUrl}}" alt="Book Cover" class="w-full h-full object-cover">
                    <!-- Global Badge -->
                    {{#unless this.installationId}}
                    <span class="absolute top-3 right-3 bg-indigo-600 text-white text-[9px] font-extrabold uppercase px-2 py-1 rounded-full shadow-md">Global Resource</span>
                    {{/unless}}
                </div>
                <!-- Content -->
                <div class="p-5 flex-grow flex flex-col justify-between space-y-4">
                    <div class="space-y-1.5">
                        <h4 class="font-bold text-gray-900 line-clamp-1 text-base">{{this.title}}</h4>
                        <p class="text-xs font-semibold text-gray-400">By {{this.author}}</p>
                        <p class="text-xs text-gray-500 line-clamp-2">{{this.description}}</p>
                    </div>
                    <!-- Actions -->
                    <div class="pt-4 border-t border-gray-50 flex items-center justify-between gap-2">
                        <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">{{formatDate this.createdAt}}</span>
                        <div class="flex items-center gap-2">
                            {{#if ../isUploader}}
                            <button onclick="openEditBookModal('{{this.id}}', '{{this.title}}', '{{this.author}}', '{{this.description}}', '{{#if this.installationId}}false{{else}}true{{/if}}')" 
                                    class="inline-flex items-center gap-1 text-xs font-bold text-amber-600 hover:text-amber-700 transition">
                                ✏️ Edit
                            </button>
                            {{/if}}
                            <a href="{{this.pdfUrl}}" target="_blank" class="inline-flex items-center gap-1.5 text-xs font-bold text-primary hover:text-accent transition">
                                📖 Read
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {{else}}
            <div class="col-span-full bg-white p-12 rounded-3xl border border-gray-100 shadow-sm text-center space-y-3">
                <div class="text-4xl">📚</div>
                <h4 class="text-lg font-bold text-gray-800">No books found</h4>
                <p class="text-sm text-gray-400">There are no books uploaded to the library catalog yet.</p>
            </div>
            {{/each}}
        </div>
    </div>

    <!-- ══════════════════ 2. COMMUNITY BULLETIN FEED PANE ══════════════════ -->
    <div id="feed-pane" class="hidden space-y-6 max-w-3xl mx-auto">
        <!-- Post Write card -->
        <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm space-y-4">
            <h3 class="text-base font-extrabold text-gray-900 flex items-center gap-2">
                ✍️ Write a Post / testimony
            </h3>
            <form action="/library/posts/create" method="POST" class="space-y-4">
                <div class="space-y-1">
                    <input type="text" name="title" placeholder="Topic / Heading (Optional)" 
                           class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition text-sm">
                </div>
                <div class="space-y-1">
                    <textarea name="content" required rows="3" placeholder="Share an announcement, a sermon note, or a testimony with members of {{installation.name}}..." 
                              class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition text-sm resize-none"></textarea>
                </div>
                <div class="flex justify-end">
                    <button type="submit" class="bg-emerald-600 text-white px-6 py-2.5 rounded-xl font-bold shadow-md hover:bg-emerald-700 transition text-sm">Publish Post</button>
                </div>
            </form>
        </div>

        <!-- Bulletin Posts Timeline -->
        <div class="space-y-4">
            {{#each posts}}
            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm space-y-4 hover:border-gray-200 transition">
                <!-- Header -->
                <div class="flex items-center gap-3">
                    <img src="{{#if this.User.profilePicture}}{{this.User.profilePicture}}{{else}}/images/default-avatar.jpg{{/if}}" 
                         alt="Author avatar" 
                         class="w-10 h-10 rounded-full object-cover border-2 border-gray-100">
                    <div class="min-w-0">
                        <div class="flex items-center gap-2 flex-wrap">
                            <h4 class="font-bold text-sm text-gray-900 leading-none">{{this.User.fullName}}</h4>
                            <span class="text-[9px] font-extrabold uppercase px-2 py-0.5 rounded-full leading-none
                                  {{#if (eq this.User.role 'superadmin')}}bg-red-50 text-red-600 border border-red-100{{/if}}
                                  {{#if (eq this.User.role 'pastor')}}bg-indigo-50 text-indigo-600 border border-indigo-100{{/if}}
                                  {{#unless (or (eq this.User.role 'superadmin') (eq this.User.role 'pastor'))}}bg-gray-100 text-gray-600{{/unless}}">
                                {{this.User.role}}
                            </span>
                        </div>
                        <p class="text-[10px] text-gray-400 mt-1 font-semibold">{{formatDate this.createdAt}}</p>
                    </div>
                </div>
                <!-- Content Body -->
                <div class="space-y-2">
                    {{#if this.title}}
                    <h5 class="font-bold text-gray-900 text-base leading-tight">{{this.title}}</h5>
                    {{/if}}
                    <p class="text-sm text-gray-700 whitespace-pre-wrap leading-relaxed">{{this.content}}</p>
                </div>
            </div>
            {{else}}
            <div class="bg-white p-12 rounded-3xl border border-gray-100 shadow-sm text-center space-y-3">
                <div class="text-4xl">💬</div>
                <h4 class="text-lg font-bold text-gray-800 font-bold">No community updates</h4>
                <p class="text-sm text-gray-400">Share something with the branch community to get the feed started!</p>
            </div>
            {{/each}}
        </div>
    </div>
</div>

<!-- Edit Book Modal -->
<div id="edit-book-modal" class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-200">
    <div class="bg-white rounded-3xl p-8 max-w-lg w-full mx-4 shadow-2xl transform scale-95 transition-transform duration-200" id="edit-book-modal-card">
        <div class="flex justify-between items-center pb-4 border-b border-gray-100">
            <h3 class="text-lg font-bold text-gray-950">✏️ Edit Book Details</h3>
            <button onclick="closeEditBookModal()" class="text-gray-400 hover:text-gray-600">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <form id="edit-book-form" method="POST" enctype="multipart/form-data" class="space-y-4 mt-4">
            <div class="space-y-1">
                <label class="text-xs font-bold text-gray-700">Book Title *</label>
                <input type="text" name="title" id="edit-book-title" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition text-sm">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold text-gray-700">Author Name</label>
                <input type="text" name="author" id="edit-book-author" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition text-sm">
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold text-gray-700">Scope Availability</label>
                <select name="isGlobal" id="edit-book-scope" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition text-sm">
                    <option value="false">Only This Branch ({{installation.name}})</option>
                    <option value="true">Global (All branches can access)</option>
                </select>
            </div>
            <div class="space-y-1">
                <label class="text-xs font-bold text-gray-700">Description</label>
                <input type="text" name="description" id="edit-book-description" class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition text-sm">
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label class="text-xs font-bold text-gray-700">Update PDF (Optional)</label>
                    <input type="file" name="bookPdf" accept="application/pdf" class="w-full text-xs text-gray-500 file:mr-2 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-primary file:text-white hover:file:opacity-90 cursor-pointer">
                </div>
                <div class="space-y-1">
                    <label class="text-xs font-bold text-gray-700">Update Cover (Optional)</label>
                    <input type="file" name="coverImage" accept="image/*" class="w-full text-xs text-gray-500 file:mr-2 file:py-2 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-bold file:bg-emerald-600 file:text-white hover:file:opacity-90 cursor-pointer">
                </div>
            </div>
            <div class="pt-4 flex justify-end gap-3 border-t border-gray-100 mt-6">
                <button type="button" onclick="closeEditBookModal()" class="px-5 py-2.5 bg-gray-100 text-gray-700 rounded-xl text-sm font-bold hover:bg-gray-200 transition">Cancel</button>
                <button type="submit" class="px-6 py-2.5 bg-primary text-white rounded-xl text-sm font-bold shadow-md hover:opacity-95 transition">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openEditBookModal(id, title, author, description, isGlobal) {
        const modal = document.getElementById('edit-book-modal');
        const card = document.getElementById('edit-book-modal-card');
        const form = document.getElementById('edit-book-form');
        
        form.action = `/library/books/edit/${id}`;
        document.getElementById('edit-book-title').value = title;
        document.getElementById('edit-book-author').value = author;
        document.getElementById('edit-book-description').value = description;
        document.getElementById('edit-book-scope').value = isGlobal;

        modal.classList.remove('hidden');
        setTimeout(() => {
            modal.classList.remove('opacity-0');
            card.classList.remove('scale-95');
        }, 10);
    }

    function closeEditBookModal() {
        const modal = document.getElementById('edit-book-modal');
        const card = document.getElementById('edit-book-modal-card');
        modal.classList.add('opacity-0');
        card.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 200);
    }

    function switchTab(activeId, inactiveId, btn) {
        // Toggle view panels
        document.getElementById(activeId).classList.remove('hidden');
        document.getElementById(inactiveId).classList.add('hidden');

        // Toggle active tabs styling
        const buttons = document.querySelectorAll('.tab-btn');
        buttons.forEach(b => {
            b.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
            b.classList.add('text-gray-600');
        });

        btn.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
        btn.classList.remove('text-gray-600');
    }
</script>
