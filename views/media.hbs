<div class="max-w-6xl mx-auto space-y-8">
    <div class="flex justify-between items-center flex-wrap gap-4">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 tracking-tight">Media Library</h2>
            <p class="text-gray-500 mt-1">Manage sermon recordings, podcast episodes, photos, and livestream links.</p>
        </div>
        <button onclick="document.getElementById('add-media-modal').classList.remove('hidden')" class="bg-primary text-white px-6 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">+ Add Media</button>
    </div>

    {{#if success}}<div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-xl"><p class="text-sm text-green-700 font-bold">{{success}}</p></div>{{/if}}
    {{#if error}}<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-sm text-red-700 font-bold">{{error}}</p></div>{{/if}}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {{#each media}}
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm hover:shadow-lg transition overflow-hidden">
            <div class="relative h-32 flex items-center justify-center
                {{#if (eq category 'audio')}}bg-gradient-to-br from-purple-500 to-indigo-600{{/if}}
                {{#if (eq category 'video')}}bg-gradient-to-br from-red-500 to-rose-600{{/if}}
                {{#if (eq category 'podcast')}}bg-gradient-to-br from-amber-500 to-orange-600{{/if}}
                {{#if (eq category 'photo')}}bg-gradient-to-br from-teal-500 to-cyan-600{{/if}}
                {{#if (eq category 'livestream')}}bg-gradient-to-br from-primary to-blue-800{{/if}}">
                <svg class="w-12 h-12 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    {{#if (eq category 'audio')}}<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path>{{/if}}
                    {{#if (eq category 'video')}}<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.876V15.124a1 1 0 01-1.447.895L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>{{/if}}
                    {{#if (eq category 'podcast')}}<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path>{{/if}}
                    {{#if (eq category 'livestream')}}<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.636 18.364a9 9 0 010-12.728m12.728 0a9 9 0 010 12.728m-9.9-2.829a5 5 0 010-7.07m7.072 0a5 5 0 010 7.07M13 12a1 1 0 11-2 0 1 1 0 012 0z"></path>{{/if}}
                </svg>
                <span class="absolute top-3 right-3 px-2 py-0.5 bg-white/20 text-white text-[10px] font-extrabold rounded-full uppercase tracking-wider
                    {{#if (eq permissions 'public')}}{{/if}}
                    {{#if (eq permissions 'private')}}bg-slate-900/30{{/if}}
                    {{#if (eq permissions 'downloadable')}}bg-emerald-500/30{{/if}}">
                    {{permissions}}
                </span>
            </div>
            <div class="p-6 space-y-3">
                <h3 class="font-bold text-gray-900 leading-tight">{{title}}</h3>
                <p class="text-sm text-gray-500">{{description}}</p>
                {{#if fileUrl}}
                <a href="{{fileUrl}}" class="inline-flex items-center gap-1.5 text-primary text-xs font-bold hover:underline">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                    Download / Access File
                </a>
                {{/if}}
                {{#if livestreamUrl}}
                <a href="{{livestreamUrl}}" target="_blank" class="inline-flex items-center gap-1.5 text-red-500 text-xs font-bold hover:underline">
                    🔴 Watch Livestream
                </a>
                {{/if}}
            </div>
        </div>
        {{else}}
        <div class="col-span-3 bg-white rounded-3xl border border-gray-100 p-16 text-center text-gray-500">
            No media items in the library yet. Add your first sermon or recording.
        </div>
        {{/each}}
    </div>

    <!-- Add Media Modal -->
    <div id="add-media-modal" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-xl font-bold">Add Media Item</h3>
                <button type="button" onclick="document.getElementById('add-media-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/media/create" method="POST" class="p-8 space-y-4">
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Title *</label>
                    <input type="text" name="title" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Description</label>
                    <textarea name="description" rows="2" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm"></textarea>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Category</label>
                        <select name="category" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                            <option value="audio">Audio</option>
                            <option value="video">Video</option>
                            <option value="podcast">Podcast</option>
                            <option value="photo">Photo</option>
                            <option value="livestream">Livestream</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Access Permissions</label>
                        <select name="permissions" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                            <option value="public">Public</option>
                            <option value="downloadable">Downloadable</option>
                            <option value="private">Private</option>
                        </select>
                    </div>
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">File URL (Audio / Video Path)</label>
                    <input type="text" name="fileUrl" placeholder="/uploads/sermon.mp3" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Livestream URL (YouTube/Zoom Link)</label>
                    <input type="url" name="livestreamUrl" placeholder="https://youtube.com/live/..." class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" onclick="document.getElementById('add-media-modal').classList.add('hidden')" class="px-6 py-3 font-bold text-gray-500">Cancel</button>
                    <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Add to Library</button>
                </div>
            </form>
        </div>
    </div>
</div>
