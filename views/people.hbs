<div class="max-w-6xl mx-auto space-y-8">
    <div class="flex justify-between items-center flex-wrap gap-4">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 tracking-tight">{{title}}</h2>
            <p class="text-gray-500 mt-1">Manage congregation members, families, and church staff for {{installation.name}}.</p>
        </div>
        <div class="flex flex-wrap gap-3">
            <button onclick="document.getElementById('add-member-modal').classList.remove('hidden')" class="bg-white border border-gray-200 text-primary px-6 py-3 rounded-xl font-bold shadow-sm hover:bg-gray-50 transition">+ Add Member</button>
            <button onclick="document.getElementById('add-person-modal').classList.remove('hidden')" class="bg-primary text-white px-6 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">+ Add Staff/Worker</button>
        </div>
    </div>

    {{#if success}}
    <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-xl">
        <p class="text-sm text-green-700 font-bold">{{success}}</p>
    </div>
    {{/if}}
    {{#if error}}
    <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl">
        <p class="text-sm text-red-700 font-bold">{{error}}</p>
    </div>
    {{/if}}

    <!-- Stats Summary -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Total Members</p>
            <h3 class="text-3xl font-extrabold mt-2 text-gray-900">{{members.length}}</h3>
        </div>
        <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Total Staff</p>
            <h3 class="text-3xl font-extrabold mt-2 text-gray-900">{{people.length}}</h3>
        </div>
        <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Linked Families</p>
            <h3 class="text-3xl font-extrabold mt-2 text-gray-900">{{families.length}}</h3>
        </div>
        <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
            <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Pending Transfers</p>
            <h3 class="text-3xl font-extrabold mt-2 text-orange-600">{{transfers.length}}</h3>
        </div>
    </div>

    <!-- Directory Section with Tabs -->
    <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="p-8 border-b border-gray-50 flex flex-col md:flex-row justify-between items-start md:items-center space-y-4 md:space-y-0">
            <div class="flex flex-wrap bg-gray-100 p-1 rounded-xl gap-1">
                <button type="button" data-target="members-table-container" class="dir-tab px-6 py-2 rounded-lg text-sm font-bold bg-white shadow-sm text-primary">Church Members</button>
                <button type="button" data-target="workers-table-container" class="dir-tab px-6 py-2 rounded-lg text-sm font-bold text-gray-500 hover:text-primary transition">Workers & Staff</button>
                <button type="button" data-target="transfers-container" class="dir-tab px-6 py-2 rounded-lg text-sm font-bold text-gray-500 hover:text-primary transition">Member Transfers ({{transfers.length}})</button>
            </div>
            <div class="flex space-x-2 w-full md:w-auto">
                <input id="search-dir" type="text" placeholder="Search directory..." class="bg-gray-50 border-none rounded-xl px-4 py-2.5 text-sm focus:ring-1 focus:ring-primary transition shadow-sm w-full md:w-64">
            </div>
        </div>

        <!-- Members Table -->
        <div class="overflow-x-auto tab-content block" id="members-table-container">
            <table class="w-full text-left">
                <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500 font-bold border-b border-gray-100">
                    <tr>
                        <th class="px-8 py-5">Name & Family</th>
                        <th class="px-8 py-5">Classification</th>
                        <th class="px-8 py-5">Contact</th>
                        <th class="px-8 py-5">Status</th>
                        <th class="px-8 py-5 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50" id="members-list">
                    {{#each members}}
                    <tr class="hover:bg-gray-50/50 transition member-row" data-name="{{fullName}}">
                        <td class="px-8 py-5">
                            <div class="flex items-center space-x-3">
                                <img class="h-10 w-10 rounded-full object-cover border border-gray-100" src="{{profilePicture}}" alt="">
                                <div>
                                    <span class="font-bold text-gray-900 block leading-tight">{{fullName}}</span>
                                    {{#if familyId}}
                                    <span class="inline-flex items-center text-[10px] font-semibold text-slate-500 bg-slate-100 px-2 py-0.5 rounded mt-0.5">
                                        {{familyRole}}
                                    </span>
                                    {{/if}}
                                </div>
                            </div>
                        </td>
                        <td class="px-8 py-5">
                            <span class="px-2.5 py-1 rounded-full text-[10px] font-extrabold uppercase tracking-wider
                                {{#if (eq classification 'visitor')}}bg-amber-100 text-amber-700{{/if}}
                                {{#if (eq classification 'new_convert')}}bg-purple-100 text-purple-700{{/if}}
                                {{#if (eq classification 'baptized')}}bg-green-100 text-green-700{{/if}}
                                {{#if (eq classification 'worker')}}bg-blue-100 text-blue-700{{/if}}">
                                {{classification}}
                            </span>
                        </td>
                        <td class="px-8 py-5">
                            <span class="text-sm text-gray-600 block">{{email}}</span>
                            <span class="text-xs text-gray-400 font-medium">{{phoneNumber}}</span>
                        </td>
                        <td class="px-8 py-5">
                            <span class="px-2.5 py-1 rounded-full text-[10px] font-extrabold uppercase tracking-wider
                                {{#if (eq status 'active')}}bg-emerald-100 text-emerald-700{{/if}}
                                {{#if (eq status 'inactive')}}bg-gray-100 text-gray-700{{/if}}
                                {{#if (eq status 'transferred')}}bg-indigo-100 text-indigo-700{{/if}}
                                {{#if (eq status 'deceased')}}bg-rose-100 text-rose-700{{/if}}">
                                {{status}}
                            </span>
                        </td>
                        <td class="px-8 py-5 text-right space-x-1">
                            <button onclick="openTransferModal('{{id}}', '{{fullName}}')" class="text-gray-400 hover:text-primary transition p-2 bg-gray-50 hover:bg-slate-100 rounded-lg inline-flex" title="Transfer member">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg>
                            </button>
                            <form action="/people/delete-member/{{id}}" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this church member?');">
                                <button type="submit" class="text-gray-400 hover:text-red-500 transition p-2 bg-gray-50 hover:bg-red-50 rounded-lg inline-flex"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button>
                            </form>
                        </td>
                    </tr>
                    {{/each}}
                    {{#unless members}}
                    <tr><td colspan="5" class="px-8 py-10 text-center text-gray-500 font-medium">No church members found. Click '+ Add Member' to register someone.</td></tr>
                    {{/unless}}
                </tbody>
            </table>
        </div>

        <!-- Workers Table -->
        <div class="overflow-x-auto tab-content hidden" id="workers-table-container">
            <table class="w-full text-left">
                <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500 font-bold border-b border-gray-100">
                    <tr>
                        <th class="px-8 py-5">Name</th>
                        <th class="px-8 py-5">Role</th>
                        <th class="px-8 py-5">Email</th>
                        <th class="px-8 py-5">Status</th>
                        <th class="px-8 py-5 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    {{#each people}}
                    <tr class="hover:bg-gray-50/50 transition">
                        <td class="px-8 py-5">
                            <div class="flex items-center space-x-3">
                                <img class="h-10 w-10 rounded-full object-cover border border-gray-100" src="{{profilePicture}}" alt="">
                                <span class="font-bold text-gray-900 block leading-tight">{{fullName}}</span>
                            </div>
                        </td>
                        <td class="px-8 py-5">
                            <span class="px-3 py-1 rounded-full text-[10px] font-extrabold uppercase tracking-wider
                                {{#if (eq role 'superadmin')}}bg-amber-100 text-amber-700{{/if}}
                                {{#if (eq role 'pastor')}}bg-blue-100 text-blue-700{{/if}}
                                {{#if (eq role 'secretary')}}bg-purple-100 text-purple-700{{/if}}
                                {{#if (eq role 'finance_officer')}}bg-emerald-100 text-emerald-700{{/if}}
                                {{#if (eq role 'hod')}}bg-pink-100 text-pink-700{{/if}}
                                {{#if (eq role 'worker')}}bg-gray-100 text-gray-700{{/if}}">
                                {{role}}
                            </span>
                        </td>
                        <td class="px-8 py-5 text-sm text-gray-600">{{email}}</td>
                        <td class="px-8 py-5">
                            <span class="flex items-center text-xs font-semibold text-emerald-600">
                                <span class="w-2.5 h-2.5 bg-emerald-500 rounded-full mr-2"></span> Active
                            </span>
                        </td>
                        <td class="px-8 py-5 text-right">
                            {{#if canDelete}}
                            <form action="/people/delete-person/{{id}}" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this staff member?');">
                                <button type="submit" class="text-gray-400 hover:text-red-500 transition p-2 bg-gray-50 hover:bg-red-50 rounded-lg inline-flex"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button>
                            </form>
                            {{/if}}
                        </td>
                    </tr>
                    {{/each}}
                    {{#unless people}}
                    <tr><td colspan="5" class="px-8 py-10 text-center text-gray-500 font-medium">No staff or workers found.</td></tr>
                    {{/unless}}
                </tbody>
            </table>
        </div>

        <!-- Transfers Management -->
        <div class="overflow-x-auto tab-content hidden p-8" id="transfers-container">
            <h4 class="text-base font-bold mb-4 text-gray-900 border-b pb-2">Inter-Branch Member Transfer Requests</h4>
            <div class="space-y-4">
                {{#each transfers}}
                <div class="border rounded-2xl p-6 flex flex-col md:flex-row justify-between items-start md:items-center bg-gray-50/50 gap-4">
                    <div class="space-y-1">
                        <div class="flex items-center space-x-2 flex-wrap">
                            <span class="font-bold text-gray-900">{{Member.fullName}}</span>
                            <span class="text-xs text-gray-400">requested by {{RequestedBy.fullName}}</span>
                        </div>
                        <div class="text-sm font-medium text-gray-600">
                            {{#if isOutward}}
                            Transferring OUTWARD to <strong class="text-primary">{{DestinationBranch.name}}</strong>
                            {{else}}
                            Transferring INWARD from <strong class="text-primary">{{SourceBranch.name}}</strong>
                            {{/if}}
                        </div>
                        {{#if notes}}<p class="text-xs text-gray-400 italic">Notes: "{{notes}}"</p>{{/if}}
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="px-2.5 py-1 rounded-full text-[10px] font-extrabold uppercase tracking-wider
                            {{#if (eq status 'pending')}}bg-amber-100 text-amber-700{{/if}}
                            {{#if (eq status 'approved_source')}}bg-blue-100 text-blue-700{{/if}}
                            {{#if (eq status 'completed')}}bg-green-100 text-green-700{{/if}}
                            {{#if (eq status 'rejected_source')}}bg-rose-100 text-rose-700{{/if}}
                            {{#if (eq status 'rejected_destination')}}bg-rose-100 text-rose-700{{/if}}">
                            {{status}}
                        </span>
                        
                        {{#if (eq status 'pending')}}
                            {{#if isOutward}}
                                {{#if canApprove}}
                                <form action="/people/transfer/{{id}}/approve" method="POST" class="inline">
                                    <button type="submit" class="bg-primary text-white text-xs px-3 py-1.5 rounded-lg font-bold shadow-sm hover:opacity-90 transition">Approve Outward</button>
                                </form>
                                <form action="/people/transfer/{{id}}/reject" method="POST" class="inline">
                                    <button type="submit" class="bg-white border text-red-500 text-xs px-3 py-1.5 rounded-lg font-bold hover:bg-red-50 transition">Reject</button>
                                </form>
                                {{/if}}
                            {{/if}}
                        {{/if}}

                        {{#if (eq status 'approved_source')}}
                            {{#if isInward}}
                                {{#if canApprove}}
                                <form action="/people/transfer/{{id}}/approve" method="POST" class="inline">
                                    <button type="submit" class="bg-emerald-600 text-white text-xs px-3 py-1.5 rounded-lg font-bold shadow-sm hover:bg-emerald-700 transition">Approve & Accept Member</button>
                                </form>
                                <form action="/people/transfer/{{id}}/reject" method="POST" class="inline">
                                    <button type="submit" class="bg-white border text-red-500 text-xs px-3 py-1.5 rounded-lg font-bold hover:bg-red-50 transition">Decline</button>
                                </form>
                                {{/if}}
                            {{/if}}
                        {{/if}}
                    </div>
                </div>
                {{else}}
                <div class="text-center py-10 text-gray-500 font-medium">No transfer requests pending for this installation.</div>
                {{/each}}
            </div>
        </div>
    </div>

    <!-- Add Member Modal -->
    <div id="add-member-modal" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-xl font-bold">Register Church Member</h3>
                <button type="button" onclick="document.getElementById('add-member-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/people/create-member" method="POST" class="p-8 space-y-4">
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Full Name *</label>
                    <input type="text" name="fullName" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Email Address</label>
                        <input type="email" name="email" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Phone Number</label>
                        <input type="tel" name="phoneNumber" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                    </div>
                </div>
                <div class="grid grid-cols-3 gap-4">
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Gender</label>
                        <select name="gender" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                            <option value="">Select...</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Classification</label>
                        <select name="classification" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                            <option value="visitor">Visitor</option>
                            <option value="new_convert">New Convert</option>
                            <option value="baptized">Baptized</option>
                            <option value="worker">Worker</option>
                        </select>
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Status</label>
                        <select name="status" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                            <option value="deceased">Deceased</option>
                        </select>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Family Unit ID (Optional)</label>
                        <input type="text" name="familyId" placeholder="UUID format" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Family Role</label>
                        <input type="text" name="familyRole" placeholder="e.g. Father, Mother, Child" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                    </div>
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Home Address</label>
                    <textarea name="address" rows="2" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm"></textarea>
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" onclick="document.getElementById('add-member-modal').classList.add('hidden')" class="px-6 py-3 font-bold text-gray-500">Cancel</button>
                    <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Save Member</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Member Transfer Modal -->
    <div id="transfer-member-modal" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-md rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-xl font-bold">Transfer Member</h3>
                <button type="button" onclick="document.getElementById('transfer-member-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/people/transfer/request" method="POST" class="p-8 space-y-4">
                <input type="hidden" name="memberId" id="transfer-member-id">
                <div>
                    <label class="block text-sm font-bold text-gray-500">Member to Transfer</label>
                    <div id="transfer-member-name" class="font-extrabold text-lg text-primary mt-1"></div>
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Destination Branch *</label>
                    <select name="destinationInstallationId" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                        <option value="">Select branch...</option>
                        {{#each installations}}
                            <option value="{{id}}">{{name}}</option>
                        {{/each}}
                    </select>
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Reason for Transfer / Notes</label>
                    <textarea name="notes" rows="3" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm" placeholder="e.g. Relocated to another city"></textarea>
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" onclick="document.getElementById('transfer-member-modal').classList.add('hidden')" class="px-6 py-3 font-bold text-gray-500">Cancel</button>
                    <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Request Transfer</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Add Person Modal (Staff) -->
    <div id="add-person-modal" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-xl font-bold">Add New Staff/Worker</h3>
                <button type="button" onclick="document.getElementById('add-person-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/people/create" method="POST" class="p-8 space-y-4">
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Full Name *</label>
                    <input type="text" name="fullName" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Email Address *</label>
                    <input type="email" name="email" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Initial Password *</label>
                    <div class="relative">
                        <input id="staff-password" type="password" name="password" required class="w-full bg-gray-50 border-none rounded-xl pl-4 pr-10 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                        <button type="button" onclick="togglePasswordVisibility('staff-password', this)" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition" title="Toggle password visibility">
                            <svg class="w-5 h-5 eye-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                            <svg class="w-5 h-5 eye-off-icon hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a10.025 10.025 0 014.132-5.4M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M3 3l18 18" />
                            </svg>
                        </button>
                    </div>
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Assigned Role</label>
                    <select name="role" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                        <option value="worker">Worker</option>
                        <option value="hod">HOD (Department Leader)</option>
                        <option value="finance_officer">Finance Officer</option>
                        <option value="secretary">Secretary</option>
                        <option value="pastor">Pastor</option>
                        <option value="global_auditor">Global Auditor</option>
                        <option value="tech_support">Tech Support</option>
                    </select>
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" onclick="document.getElementById('add-person-modal').classList.add('hidden')" class="px-6 py-3 font-bold text-gray-500">Cancel</button>
                    <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Create Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openTransferModal(id, name) {
        document.getElementById('transfer-member-id').value = id;
        document.getElementById('transfer-member-name').textContent = name;
        document.getElementById('transfer-member-modal').classList.remove('hidden');
    }

    document.addEventListener('DOMContentLoaded', () => {
        // Tab switching
        const dirTabs = document.querySelectorAll('.dir-tab');
        const tabContents = document.querySelectorAll('.tab-content');

        dirTabs.forEach(tab => {
            tab.addEventListener('click', (e) => {
                e.preventDefault();
                dirTabs.forEach(t => {
                    t.classList.remove('bg-white', 'shadow-sm', 'text-primary');
                    t.classList.add('text-gray-500');
                });
                tabContents.forEach(content => {
                    content.classList.remove('block');
                    content.classList.add('hidden');
                });
                tab.classList.remove('text-gray-500');
                tab.classList.add('bg-white', 'shadow-sm', 'text-primary');

                const targetId = tab.dataset.target;
                if (targetId) {
                    const targetContent = document.getElementById(targetId);
                    if (targetContent) {
                        targetContent.classList.remove('hidden');
                        targetContent.classList.add('block');
                    }
                }
            });
        });

        // Simple Directory Search
        const searchInput = document.getElementById('search-dir');
        searchInput.addEventListener('input', () => {
            const query = searchInput.value.toLowerCase();
            const rows = document.querySelectorAll('.member-row');
            rows.forEach(row => {
                const name = row.dataset.name.toLowerCase();
                if (name.includes(query)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    });

    function togglePasswordVisibility(inputId, btn) {
        const input = document.getElementById(inputId);
        const eyeIcon = btn.querySelector('.eye-icon');
        const eyeOffIcon = btn.querySelector('.eye-off-icon');
        if (input.type === 'password') {
            input.type = 'text';
            eyeIcon.classList.add('hidden');
            eyeOffIcon.classList.remove('hidden');
        } else {
            input.type = 'password';
            eyeIcon.classList.remove('hidden');
            eyeOffIcon.classList.add('hidden');
        }
    }
</script>
