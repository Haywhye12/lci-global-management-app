<div class="space-y-8">
    <div class="flex justify-between items-end">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 tracking-tight">Installation Dashboard</h2>
            <p class="text-gray-500 mt-1">Welcome back, overview for {{installation.name}}.</p>
        </div>
        <div class="flex space-x-3">
            {{#if (eq user.role 'admin')}}
            <button onclick="document.getElementById('export-modal').classList.remove('hidden')" class="bg-white border text-gray-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-50 transition shadow-sm flex items-center space-x-2">
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                <span>Export Report</span>
            </button>
            {{else}}
                {{#if (eq user.role 'superadmin')}}
                <button onclick="document.getElementById('export-modal').classList.remove('hidden')" class="bg-white border text-gray-700 px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-50 transition shadow-sm flex items-center space-x-2">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    <span>Export Report</span>
                </button>
                {{/if}}
            {{/if}}
            <div class="relative group">
                <button class="bg-primary text-white px-4 py-2 rounded-lg text-sm font-semibold hover:opacity-90 transition shadow-md flex items-center space-x-2">
                    <span>+ New Entry</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>
                <div class="absolute right-0 mt-2 w-52 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                    <div class="py-2">
                        <a href="/attendance" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary font-medium transition">Record Attendance</a>
                        <a href="/finance" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary font-medium transition">Add Finance Data</a>
                        <a href="/first-timers" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary font-medium transition">Register First Timer</a>
                        <a href="/people" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary font-medium transition">Add New Member</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition">
            <div class="flex items-center justify-between mb-4">
                <div class="p-3 bg-blue-50 rounded-xl text-blue-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                </div>
                <span class="text-xs font-bold text-green-500 bg-green-50 px-2 py-1 rounded-full">+12%</span>
            </div>
            <p class="text-sm font-medium text-gray-500">Average Attendance</p>
            <h3 class="text-2xl font-bold mt-1 text-gray-900">1,240</h3>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition">
            <div class="flex items-center justify-between mb-4">
                <div class="p-3 bg-green-50 rounded-xl text-green-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <span class="text-xs font-bold text-green-500 bg-green-50 px-2 py-1 rounded-full">+8%</span>
            </div>
            <p class="text-sm font-medium text-gray-500">Gross Monthly Income</p>
            <h3 class="text-2xl font-bold mt-1 text-gray-900">₦2,450,000</h3>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition">
            <div class="flex items-center justify-between mb-4">
                <div class="p-3 bg-purple-50 rounded-xl text-purple-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path></svg>
                </div>
                <span class="text-xs font-bold text-blue-500 bg-blue-50 px-2 py-1 rounded-full">New</span>
            </div>
            <p class="text-sm font-medium text-gray-500">First Timers</p>
            <h3 class="text-2xl font-bold mt-1 text-gray-900">42</h3>
        </div>

        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition">
            <div class="flex items-center justify-between mb-4">
                <div class="p-3 bg-orange-50 rounded-xl text-orange-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
                <span class="text-xs font-bold text-orange-500 bg-orange-50 px-2 py-1 rounded-full">94%</span>
            </div>
            <p class="text-sm font-medium text-gray-500">Report Status</p>
            <h3 class="text-2xl font-bold mt-1 text-gray-900 text-orange-600">Pending</h3>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-8">
            <!-- Attendance Chart Component -->
            <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm relative">
                <h3 class="text-lg font-bold mb-6">Attendance Trends</h3>
                <div class="relative h-64 w-full">
                    <canvas id="attendanceChart"></canvas>
                </div>
            </div>

            <!-- Chart.js and initialization script -->
            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    const ctx = document.getElementById('attendanceChart').getContext('2d');
                    
                    // Create gradient for the line chart fill
                    const gradient = ctx.createLinearGradient(0, 0, 0, 300);
                    gradient.addColorStop(0, 'rgba(26, 54, 93, 0.4)'); // Primary color with opacity
                    gradient.addColorStop(1, 'rgba(26, 54, 93, 0.0)');

                    new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                            datasets: [{
                                label: 'Average Weekly Attendance',
                                data: [850, 920, 1050, 1100, 1240, 1310],
                                borderColor: '#1a365d', // Primary color
                                backgroundColor: gradient,
                                borderWidth: 3,
                                pointBackgroundColor: '#ffffff',
                                pointBorderColor: '#1a365d',
                                pointBorderWidth: 2,
                                pointRadius: 4,
                                pointHoverRadius: 6,
                                fill: true,
                                tension: 0.4 // Smooth curves
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: {
                                    display: false // Hide legend for cleaner look
                                },
                                tooltip: {
                                    backgroundColor: 'rgba(255, 255, 255, 0.95)',
                                    titleColor: '#1a365d',
                                    bodyColor: '#4b5563',
                                    borderColor: '#e5e7eb',
                                    borderWidth: 1,
                                    padding: 12,
                                    displayColors: false,
                                    callbacks: {
                                        label: function(context) {
                                            return context.parsed.y + ' Attendees';
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    grid: {
                                        color: '#f3f4f6',
                                        drawBorder: false
                                    },
                                    ticks: {
                                        color: '#9ca3af',
                                        font: {
                                            family: "'Outfit', sans-serif"
                                        }
                                    }
                                },
                                x: {
                                    grid: {
                                        display: false,
                                        drawBorder: false
                                    },
                                    ticks: {
                                        color: '#9ca3af',
                                        font: {
                                            family: "'Outfit', sans-serif"
                                        }
                                    }
                                }
                            },
                            interaction: {
                                intersect: false,
                                mode: 'index',
                            },
                        }
                    });
                });
            </script>

            <!-- 📰 Branch News Feed Component -->
            <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm space-y-6">
                <div>
                    <h3 class="text-xl font-extrabold text-gray-900 flex items-center gap-2">
                        📰 Branch News Feed
                    </h3>
                    <p class="text-xs text-gray-400 mt-1">Share stories, announcements, and upload pictures with other members of your branch.</p>
                </div>

                {{#if success}}
                <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-xl">
                    <p class="text-xs text-green-700 font-bold">🎉 {{success}}</p>
                </div>
                {{/if}}
                {{#if error}}
                <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl">
                    <p class="text-xs text-red-700 font-bold">⚠️ {{error}}</p>
                </div>
                {{/if}}

                <!-- Post Composer (Accessible to all members/staff) -->
                <form action="/dashboard/post" method="POST" enctype="multipart/form-data" class="space-y-4 bg-gray-50/50 p-5 rounded-2xl border border-gray-50">
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-gray-700 ml-1">Write an Update...</label>
                        <textarea name="content" required rows="3" placeholder="What is happening in {{installation.name}} today? Share a note or testimony..." 
                                  class="w-full bg-white border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary transition resize-none outline-none shadow-sm"></textarea>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 pt-2">
                        <div class="space-y-1">
                            <label class="block text-[10px] font-extrabold uppercase tracking-wider text-gray-400 ml-1">Attach Picture (Optional)</label>
                            <input type="file" name="feedImage" accept="image/*" 
                                   class="text-xs text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-[10px] file:font-extrabold file:bg-primary file:text-white hover:file:opacity-90 cursor-pointer">
                            <p class="text-[9px] text-red-500 font-bold">NB: Pictures only, no videos. Max limit 5MB.</p>
                        </div>
                        <button type="submit" class="bg-primary text-white px-6 py-2.5 rounded-xl font-bold text-xs shadow-md hover:opacity-95 transition self-end sm:self-center">
                            Publish Update
                        </button>
                    </div>
                </form>

                <!-- Feed Timeline -->
                <div class="space-y-4 max-h-[500px] overflow-y-auto pr-1">
                    {{#each feedPosts}}
                    <div class="p-5 rounded-2xl border border-gray-50 bg-white hover:border-gray-100 transition space-y-4">
                        <!-- Post Meta Header -->
                        <div class="flex items-center gap-3">
                            <img src="{{#if this.User.profilePicture}}{{this.User.profilePicture}}{{else}}/images/default-avatar.jpg{{/if}}" 
                                 alt="Avatar" 
                                 class="w-9 h-9 rounded-full object-cover border border-gray-100">
                            <div class="min-w-0">
                                <div class="flex items-center gap-2 flex-wrap">
                                    <h4 class="font-bold text-xs text-gray-900 leading-none">{{this.User.fullName}}</h4>
                                    <span class="text-[8px] font-extrabold uppercase px-1.5 py-0.5 rounded-full leading-none
                                          {{#if (eq this.User.role 'superadmin')}}bg-red-50 text-red-600 border border-red-100{{/if}}
                                          {{#if (eq this.User.role 'pastor')}}bg-indigo-50 text-indigo-600 border border-indigo-100{{/if}}
                                          {{#unless (or (eq this.User.role 'superadmin') (eq this.User.role 'pastor'))}}bg-gray-100 text-gray-600{{/unless}}">
                                        {{this.User.role}}
                                    </span>
                                </div>
                                <p class="text-[9px] text-gray-400 mt-1 font-semibold">{{formatDate this.createdAt}}</p>
                            </div>
                        </div>

                        <!-- Post Text -->
                        <p class="text-xs text-gray-700 leading-relaxed whitespace-pre-wrap">{{this.content}}</p>

                        <!-- Attached Image -->
                        {{#if this.imageUrl}}
                        <div class="rounded-xl overflow-hidden bg-gray-50 max-h-72 border border-gray-50">
                            <img src="{{this.imageUrl}}" alt="Attached Image" class="w-full h-full object-cover hover:scale-105 transition duration-500">
                        </div>
                        {{/if}}
                    </div>
                    {{else}}
                    <div class="text-center py-8 space-y-2">
                        <div class="text-2xl">📰</div>
                        <h4 class="text-xs font-bold text-gray-400">No updates in this branch feed yet</h4>
                        <p class="text-[10px] text-gray-400">Be the first to share an update or testimony!</p>
                    </div>
                    {{/each}}
                </div>
            </div>

            <!-- Recent Reports Table -->
            <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="p-6 border-b border-gray-50 flex justify-between items-center">
                    <h3 class="text-lg font-bold">Recent Weekly Reports</h3>
                    <a href="/attendance" class="text-primary text-sm font-semibold hover:underline">View All</a>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-gray-50 text-xs uppercase tracking-wider text-gray-500 font-bold">
                            <tr>
                                <th class="px-6 py-4">Service Week</th>
                                <th class="px-6 py-4">Attendance</th>
                                <th class="px-6 py-4">Income</th>
                                <th class="px-6 py-4">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-6 py-4 font-medium text-sm">Week 1 - May 2026</td>
                                <td class="px-6 py-4 text-sm">1,150</td>
                                <td class="px-6 py-4 text-sm font-semibold">₦580,000</td>
                                <td class="px-6 py-4 text-sm"><span class="bg-green-100 text-green-700 px-2 py-1 rounded-md text-xs font-bold">Verified</span></td>
                            </tr>
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-6 py-4 font-medium text-sm">Week 2 - May 2026</td>
                                <td class="px-6 py-4 text-sm">1,210</td>
                                <td class="px-6 py-4 text-sm font-semibold">₦620,000</td>
                                <td class="px-6 py-4 text-sm"><span class="bg-green-100 text-green-700 px-2 py-1 rounded-md text-xs font-bold">Verified</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Sidebar Actions -->
        <div class="space-y-6">
            <div class="bg-primary p-8 rounded-3xl text-white shadow-xl shadow-blue-200">
                <h3 class="text-xl font-bold mb-2">Monthly Target</h3>
                <p class="text-blue-100 text-sm mb-6">You've reached 75% of your attendance goal for May.</p>
                <div class="w-full bg-blue-900/30 rounded-full h-3 mb-6">
                    <div class="bg-white h-3 rounded-full shadow-sm" style="width: 75%"></div>
                </div>
                <button class="w-full bg-white text-primary py-3 rounded-xl font-bold text-sm hover:bg-blue-50 transition">View Growth Plan</button>
            </div>

            <div class="bg-white p-6 rounded-3xl border border-gray-100 shadow-sm">
                <h3 class="text-lg font-bold mb-4">Quick Links</h3>
                <div class="space-y-3">
                    <a href="/profile" class="flex items-center space-x-3 p-3 rounded-xl hover:bg-gray-50 transition">
                        <div class="w-10 h-10 bg-orange-100 text-orange-600 rounded-lg flex items-center justify-center font-bold">P</div>
                        <span class="text-sm font-medium">Update My Profile</span>
                    </a>
                    <a href="/first-timers" class="flex items-center space-x-3 p-3 rounded-xl hover:bg-gray-50 transition">
                        <div class="w-10 h-10 bg-purple-100 text-purple-600 rounded-lg flex items-center justify-center font-bold">F</div>
                        <span class="text-sm font-medium">New First Timer</span>
                    </a>
                    <a href="/departments" class="flex items-center space-x-3 p-3 rounded-xl hover:bg-gray-50 transition">
                        <div class="w-10 h-10 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center font-bold">D</div>
                        <span class="text-sm font-medium">Department Roster</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Export Modal -->
<div id="export-modal" class="fixed inset-0 bg-gray-900 bg-opacity-50 hidden z-50 flex items-center justify-center backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md overflow-hidden transform transition-all">
        <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50">
            <h3 class="text-xl font-bold text-gray-900">Export Report</h3>
            <button onclick="document.getElementById('export-modal').classList.add('hidden')" class="text-gray-400 hover:text-red-500 transition">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        
        <form action="/export" method="GET" class="p-6 space-y-6">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Report Type</label>
                    <select name="type" required class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary outline-none transition">
                        <option value="attendance">Attendance Report</option>
                        <option value="finance">Finance Report</option>
                    </select>
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Month</label>
                        <select name="month" required class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary outline-none transition">
                            <option value="1">January</option>
                            <option value="2">February</option>
                            <option value="3">March</option>
                            <option value="4">April</option>
                            <option value="5">May</option>
                            <option value="6">June</option>
                            <option value="7">July</option>
                            <option value="8">August</option>
                            <option value="9">September</option>
                            <option value="10">October</option>
                            <option value="11">November</option>
                            <option value="12">December</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-gray-700 mb-2">Year</label>
                        <input type="number" name="year" required min="2000" max="2100" value="2026" class="w-full bg-white border border-gray-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary outline-none transition">
                    </div>
                </div>
            </div>
            
            <div class="pt-4 flex space-x-3">
                <button type="button" onclick="document.getElementById('export-modal').classList.add('hidden')" class="flex-1 bg-gray-100 text-gray-700 px-4 py-3 rounded-xl font-bold hover:bg-gray-200 transition">Cancel</button>
                <button type="submit" class="flex-1 bg-primary text-white px-4 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Download CSV</button>
            </div>
        </form>
    </div>
</div>
