<div class="max-w-5xl mx-auto space-y-8">
    <div class="flex justify-between items-end">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 tracking-tight">My Profile & Branch Settings</h2>
            <p class="text-gray-500 mt-1">Manage your account information and church branch brand styling settings.</p>
        </div>
    </div>

    {{#if success}}
    <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-xl">
        <p class="text-sm text-green-700 font-bold">{{success}}</p>
    </div>
    {{/if}}
    {{#if error}}
    <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl">
        <p class="text-sm text-red-700 font-bold">{{error}}</p>
    </div>
    {{/if}}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Profile Picture Sidebar -->
        <div class="lg:col-span-1 space-y-6">
            <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm flex flex-col items-center text-center">
                <div class="relative group">
                    <img id="profile-preview" class="h-40 w-40 rounded-full object-cover border-4 border-gray-50 group-hover:opacity-95 transition shadow-lg" 
                         src="{{user.profilePicture}}" alt="Profile">
                    <label for="profile-upload" class="absolute bottom-2 right-2 bg-primary text-white p-2 rounded-full cursor-pointer shadow-lg hover:scale-110 transition">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    </label>
                    <form id="upload-form" action="/profile/upload" method="POST" enctype="multipart/form-data" class="hidden">
                        <input type="file" id="profile-upload" name="profilePicture" accept="image/*" onchange="this.form.submit()">
                    </form>
                </div>
                <h3 class="text-xl font-bold mt-4 text-gray-900">{{user.fullName}}</h3>
                <p class="text-gray-500 text-sm font-medium uppercase tracking-widest mt-1">{{user.role}}</p>
                <div class="mt-2 text-xs text-red-500 font-bold bg-red-50 px-3 py-1 rounded-full border border-red-100">
                    NB: Max size limit is 5MB
                </div>
                <div class="mt-6 w-full pt-6 border-t border-gray-50 space-y-3 text-left">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-400 font-medium">Installation</span>
                        <span class="font-bold text-gray-700 text-right">{{installation.name}}</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Account Details Form -->
        <div class="lg:col-span-2 space-y-8">
            <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
                <h3 class="text-lg font-bold mb-6 text-gray-900 border-b border-gray-50 pb-4">Personal Information</h3>
                <form action="/profile/update" method="POST" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-700 ml-1">Full Name *</label>
                            <input type="text" name="fullName" required value="{{user.fullName}}" 
                                   class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-700 ml-1">Email Address *</label>
                            <input type="email" name="email" required value="{{user.email}}" 
                                   class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                        </div>
                    </div>

                    <div class="pt-6 border-t border-gray-50">
                        <h3 class="text-lg font-bold mb-6 text-gray-900">Change Password</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-gray-700 ml-1">New Password</label>
                                <input type="password" name="newPassword" placeholder="••••••••"
                                       class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-bold text-gray-700 ml-1">Confirm Password</label>
                                <input type="password" name="confirmPassword" placeholder="••••••••"
                                       class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                            </div>
                        </div>
                    </div>

                    <div class="pt-4 flex justify-end">
                        <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Save Changes</button>
                    </div>
                </form>
            </div>

            <!-- Branch Branding Logo & Customization Settings Panel -->
            {{#if isBranchAdmin}}
            <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
                <h3 class="text-lg font-bold mb-6 text-gray-900 border-b border-gray-50 pb-4">Branch Settings & branding logo</h3>
                <form action="/profile/branch/update" method="POST" enctype="multipart/form-data" class="space-y-6">
                    <div class="flex items-center space-x-6 pb-6 border-b border-gray-50">
                        <img class="h-20 w-20 rounded-2xl object-contain bg-gray-50 border border-gray-100 shadow-sm" 
                             src="{{installation.logoUrl}}" alt="Branch Logo">
                        <div class="space-y-2">
                            <label class="block text-sm font-bold text-gray-700">Change Branch Logo</label>
                            <input type="file" name="logo" accept="image/*" class="text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-extrabold file:bg-primary file:text-white hover:file:opacity-90 cursor-pointer">
                            <p class="text-xs text-gray-400">Supported formats: JPEG, PNG, WEBP. <span class="text-red-500 font-bold">NB: Max size limit is 5MB.</span></p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-700 ml-1">Branch Name *</label>
                            <input type="text" name="name" required value="{{installation.name}}" 
                                   class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-700 ml-1">Currency Code *</label>
                            <select name="currency" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                                <option value="NGN" {{#if (eq installation.currency 'NGN')}}selected{{/if}}>NGN (₦ - Nigerian Naira)</option>
                                <option value="GHS" {{#if (eq installation.currency 'GHS')}}selected{{/if}}>GHS (₵ - Ghanaian Cedi)</option>
                                <option value="USD" {{#if (eq installation.currency 'USD')}}selected{{/if}}>USD ($ - US Dollar)</option>
                                <option value="GBP" {{#if (eq installation.currency 'GBP')}}selected{{/if}}>GBP (£ - British Pound Sterling)</option>
                                <option value="EUR" {{#if (eq installation.currency 'EUR')}}selected{{/if}}>EUR (€ - Euro)</option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-700 ml-1">Timezone *</label>
                            <select name="timezone" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                                <option value="Africa/Lagos" {{#if (eq installation.timezone 'Africa/Lagos')}}selected{{/if}}>Africa/Lagos (West Africa Time)</option>
                                <option value="Africa/Accra" {{#if (eq installation.timezone 'Africa/Accra')}}selected{{/if}}>Africa/Accra (Greenwich Mean Time)</option>
                                <option value="America/New_York" {{#if (eq installation.timezone 'America/New_York')}}selected{{/if}}>America/New_York (Eastern Time)</option>
                                <option value="Europe/London" {{#if (eq installation.timezone 'Europe/London')}}selected{{/if}}>Europe/London (British Time)</option>
                            </select>
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-700 ml-1">Contact Email</label>
                            <input type="email" name="contactEmail" value="{{installation.contactEmail}}" 
                                   class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-700 ml-1">Contact Phone</label>
                            <input type="text" name="contactPhone" value="{{installation.contactPhone}}" 
                                   class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-700 ml-1">Country</label>
                            <input type="text" name="country" value="{{installation.country}}" 
                                   class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-gray-700 ml-1">Region / State</label>
                            <input type="text" name="region" value="{{installation.region}}" 
                                   class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                        </div>
                    </div>

                    <div class="pt-4 flex justify-end">
                        <button type="submit" class="bg-emerald-600 text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:bg-emerald-700 transition">Update Branch Branding</button>
                    </div>
                </form>
            </div>
            {{/if}}
        </div>
    </div>
</div>
