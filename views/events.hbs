<div class="max-w-6xl mx-auto space-y-8">
    <div class="flex justify-between items-center flex-wrap gap-4">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 tracking-tight">Events & Calendar</h2>
            <p class="text-gray-500 mt-1">Schedule church events, programmes, and register members for participation.</p>
        </div>
        <button onclick="document.getElementById('create-event-modal').classList.remove('hidden')" class="bg-primary text-white px-6 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">+ Create Event</button>
    </div>

    {{#if success}}<div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-xl"><p class="text-sm text-green-700 font-bold">{{success}}</p></div>{{/if}}
    {{#if error}}<div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl"><p class="text-sm text-red-700 font-bold">{{error}}</p></div>{{/if}}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {{#each events}}
        <div class="bg-white rounded-3xl border border-gray-100 shadow-sm hover:shadow-lg transition overflow-hidden flex flex-col">
            <div class="bg-gradient-to-br from-primary to-blue-800 h-24 flex items-end p-6">
                <span class="text-white text-xs font-bold uppercase tracking-widest bg-white/20 px-3 py-1 rounded-full">{{eventDate}}</span>
            </div>
            <div class="p-6 flex-1 space-y-4">
                <h3 class="text-lg font-bold text-gray-900 leading-tight">{{title}}</h3>
                <p class="text-sm text-gray-500">{{description}}</p>
                <div class="space-y-2 text-sm">
                    {{#if location}}<div class="flex items-center gap-2 text-gray-600">
                        <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        {{location}}
                    </div>{{/if}}
                    {{#if livestreamLink}}<div class="flex items-center gap-2">
                        <a href="{{livestreamLink}}" target="_blank" class="text-primary font-bold text-xs flex items-center gap-1.5 hover:underline">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.876V15.124a1 1 0 01-1.447.895L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
                            Watch Livestream
                        </a>
                    </div>{{/if}}
                </div>
                <div class="flex items-center justify-between pt-4 border-t border-gray-50">
                    <span class="text-xs text-gray-400 font-semibold">{{registrationCount}} Registered</span>
                    <form action="/events/{{id}}/delete" method="POST" class="inline" onsubmit="return confirm('Delete this event?')">
                        <button type="submit" class="text-gray-400 hover:text-red-500 transition p-1.5 bg-gray-50 hover:bg-red-50 rounded-lg">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                        </button>
                    </form>
                </div>
            </div>
        </div>
        {{else}}
        <div class="col-span-3 bg-white rounded-3xl border border-gray-100 p-16 text-center text-gray-500">
            No upcoming events. Create one to get started.
        </div>
        {{/each}}
    </div>

    <!-- Create Event Modal -->
    <div id="create-event-modal" class="hidden fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                <h3 class="text-xl font-bold">Create New Event</h3>
                <button type="button" onclick="document.getElementById('create-event-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form action="/events/create" method="POST" class="p-8 space-y-4">
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Event Title *</label>
                    <input type="text" name="title" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Description</label>
                    <textarea name="description" rows="2" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm"></textarea>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Date & Time *</label>
                        <input type="datetime-local" name="eventDate" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                    </div>
                    <div class="space-y-1">
                        <label class="text-sm font-bold text-gray-700 ml-1">Location / Venue</label>
                        <input type="text" name="location" class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm" placeholder="e.g. Main Auditorium">
                    </div>
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-bold text-gray-700 ml-1">Livestream Link (Optional)</label>
                    <input type="url" name="livestreamLink" placeholder="https://youtube.com/live/..." class="w-full bg-gray-50 border-none rounded-xl px-4 py-2.5 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" onclick="document.getElementById('create-event-modal').classList.add('hidden')" class="px-6 py-3 font-bold text-gray-500">Cancel</button>
                    <button type="submit" class="bg-primary text-white px-8 py-3 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Create Event</button>
                </div>
            </form>
        </div>
    </div>
</div>
