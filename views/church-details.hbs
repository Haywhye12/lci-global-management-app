<div class="max-w-5xl mx-auto space-y-8 animate-fadeIn">
    <!-- Header -->
    <div class="flex justify-between items-end">
        <div>
            <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight">Church Details</h2>
            <p class="text-gray-500 mt-1">Manage branding, location, timezone, currency, and portal configurations for this branch installation.</p>
        </div>
    </div>

    <!-- Notifications -->
    {{#if success}}
    <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-xl shadow-sm flex items-center gap-3">
        <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p class="text-sm text-green-800 font-bold">{{success}}</p>
    </div>
    {{/if}}
    {{#if error}}
    <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl shadow-sm flex items-center gap-3">
        <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p class="text-sm text-red-800 font-bold">{{error}}</p>
    </div>
    {{/if}}

    <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
        <form action="/church-details/update" method="POST" enctype="multipart/form-data" class="space-y-8">
            
            <!-- Logo Upload Section -->
            <div class="flex flex-col sm:flex-row items-center gap-6 pb-8 border-b border-gray-100">
                <div class="relative group">
                    <img class="h-24 w-24 rounded-2xl object-contain bg-gray-50 border border-gray-100 shadow-inner group-hover:scale-[1.02] transition duration-300" 
                         src="{{installation.logoUrl}}" alt="Branch Logo">
                </div>
                <div class="space-y-2 text-center sm:text-left">
                    <label class="block text-sm font-bold text-gray-800">Branch Logo & Icon</label>
                    <input type="file" name="logo" accept="image/*" class="text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-extrabold file:bg-primary file:text-white hover:file:opacity-90 cursor-pointer">
                    <p class="text-xs text-gray-400">Supported formats: JPEG, PNG, WEBP. <span class="text-red-500 font-bold">Max size limit is 5MB.</span></p>
                </div>
            </div>

            <!-- Profile Info Fields -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Name -->
                <div class="space-y-2">
                    <label class="text-sm font-bold text-gray-700 ml-1">Branch / Installation Name *</label>
                    <input type="text" name="name" required value="{{installation.name}}" 
                           class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>

                <!-- Subdomain -->
                <div class="space-y-2">
                    <label class="text-sm font-bold text-gray-700 ml-1">Portal Subdomain</label>
                    <div class="flex rounded-xl shadow-sm bg-gray-50">
                        <input type="text" name="subdomain" value="{{installation.subdomain}}" placeholder="e.g. lagos"
                               class="flex-grow bg-transparent border-none rounded-l-xl px-4 py-3 focus:ring-2 focus:ring-primary transition">
                        <span class="inline-flex items-center px-4 rounded-r-xl border-l border-gray-200 text-sm font-bold text-gray-400">
                            .leaderschurchinternational.org
                        </span>
                    </div>
                    <p class="text-[11px] text-gray-400 ml-1">Leave blank to disable dedicated subdomain access for this branch.</p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Location -->
                <div class="space-y-2">
                    <label class="text-sm font-bold text-gray-700 ml-1">Physical Location Address</label>
                    <input type="text" name="location" value="{{installation.location}}" placeholder="e.g. 12 Adewale Close, Ikeja"
                           class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>

                <!-- Currency -->
                <div class="space-y-2">
                    <label class="text-sm font-bold text-gray-700 ml-1">Preferred Currency *</label>
                    <select name="currency" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                        <option value="NGN" {{#if (eq installation.currency 'NGN')}}selected{{/if}}>NGN (₦ - Nigerian Naira)</option>
                        <option value="GHS" {{#if (eq installation.currency 'GHS')}}selected{{/if}}>GHS (₵ - Ghanaian Cedi)</option>
                        <option value="USD" {{#if (eq installation.currency 'USD')}}selected{{/if}}>USD ($ - US Dollar)</option>
                        <option value="GBP" {{#if (eq installation.currency 'GBP')}}selected{{/if}}>GBP (£ - British Pound Sterling)</option>
                        <option value="EUR" {{#if (eq installation.currency 'EUR')}}selected{{/if}}>EUR (€ - Euro)</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Timezone -->
                <div class="space-y-2">
                    <label class="text-sm font-bold text-gray-700 ml-1">Operational Timezone *</label>
                    <select name="timezone" required class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                        <option value="Africa/Lagos" {{#if (eq installation.timezone 'Africa/Lagos')}}selected{{/if}}>Africa/Lagos (West Africa Time)</option>
                        <option value="Africa/Accra" {{#if (eq installation.timezone 'Africa/Accra')}}selected{{/if}}>Africa/Accra (Greenwich Mean Time)</option>
                        <option value="America/New_York" {{#if (eq installation.timezone 'America/New_York')}}selected{{/if}}>America/New_York (Eastern Time)</option>
                        <option value="Europe/London" {{#if (eq installation.timezone 'Europe/London')}}selected{{/if}}>Europe/London (British Time)</option>
                    </select>
                </div>

                <!-- Contact Email -->
                <div class="space-y-2">
                    <label class="text-sm font-bold text-gray-700 ml-1">Contact Email Address</label>
                    <input type="email" name="contactEmail" value="{{installation.contactEmail}}" placeholder="e.g. info@branch.lci.org"
                           class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Contact Phone -->
                <div class="space-y-2">
                    <label class="text-sm font-bold text-gray-700 ml-1">Contact Phone Number</label>
                    <input type="text" name="contactPhone" value="{{installation.contactPhone}}" placeholder="e.g. +234 800 000 0000"
                           class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>

                <!-- Country -->
                <div class="space-y-2">
                    <label class="text-sm font-bold text-gray-700 ml-1">Country</label>
                    <input type="text" name="country" value="{{installation.country}}" placeholder="e.g. Nigeria"
                           class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>

                <!-- Region / State -->
                <div class="space-y-2">
                    <label class="text-sm font-bold text-gray-700 ml-1">Region / State</label>
                    <input type="text" name="region" value="{{installation.region}}" placeholder="e.g. Lagos"
                           class="w-full bg-gray-50 border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary transition shadow-sm">
                </div>
            </div>

            <!-- Submit Button -->
            <div class="pt-6 border-t border-gray-100 flex justify-end">
                <button type="submit" class="bg-primary hover:opacity-95 text-white px-8 py-3.5 rounded-xl font-bold shadow-lg shadow-primary/20 hover:scale-[1.01] transition duration-200">
                    Save Church Details
                </button>
            </div>
        </form>
    </div>
</div>
