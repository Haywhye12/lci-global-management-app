<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="icon" type="image/jpeg" href="/images/logo.jpg">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#1a365d',
                        secondary: '#2d3748',
                        accent: '#ed8936',
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Outfit', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-3xl border border-gray-100 shadow-2xl">
        <div class="text-center">
            <img src="/images/logo.jpg" alt="LCI Logo" class="mx-auto w-16 h-16 object-contain rounded-2xl mb-6 shadow-md">
            <h2 class="text-3xl font-extrabold text-gray-900 tracking-tight">Forgot Password?</h2>
            <p class="mt-2 text-sm text-gray-500 font-medium">Enter your email and we'll generate a reset link.</p>
        </div>

        {{#if error}}
        <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-xl">
            <p class="text-sm text-red-700 font-bold">{{error}}</p>
        </div>
        {{/if}}

        {{#if success}}
        <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-xl space-y-3">
            <p class="text-sm text-green-700 font-bold">{{success}}</p>
            <a href="{{resetLink}}" class="block text-xs font-mono break-all text-primary bg-white p-3 rounded-lg border hover:bg-slate-50 transition">
                {{resetLink}}
            </a>
            <p class="text-[10px] text-gray-400">Click the link above to proceed with password reset.</p>
        </div>
        {{/if}}

        <form class="mt-8 space-y-6" action="/auth/forgot-password" method="POST">
            <div class="space-y-4">
                <div class="space-y-1">
                    <label for="email" class="text-sm font-bold text-gray-700 ml-1">Email Address</label>
                    <input id="email" name="email" type="email" autocomplete="email" required 
                        class="appearance-none relative block w-full px-4 py-3 border-none bg-gray-50 text-gray-900 rounded-xl focus:outline-none focus:ring-2 focus:ring-primary transition shadow-sm" 
                        placeholder="pastor@leaderschurch.org">
                </div>
            </div>

            <div>
                <button type="submit" class="w-full py-4 px-4 text-sm font-bold rounded-xl text-white bg-primary hover:opacity-95 transition shadow-xl shadow-blue-100">
                    Generate Reset Link
                </button>
            </div>
        </form>

        <div class="text-center mt-6">
            <a href="/auth/login" class="text-sm font-bold text-primary hover:underline">&larr; Back to Login</a>
        </div>
    </div>
</body>
</html>
