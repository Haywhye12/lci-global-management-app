<div class="max-w-6xl mx-auto space-y-8">
    <div class="flex justify-between items-end">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 tracking-tight">Finance Management</h2>
            <p class="text-gray-500 mt-1">Record tithes, offerings, and manage expenditures for {{monthName}} {{year}}.</p>
        </div>
        <div class="flex space-x-3">
            <input type="month" id="finance-month" value="{{year}}-{{month}}" onchange="window.location.href = '/finance?month=' + this.value" class="bg-white border border-gray-200 rounded-xl px-4 py-2 text-sm font-semibold shadow-sm focus:ring-2 focus:ring-primary outline-none transition">
            <button class="bg-white border text-gray-700 px-6 py-2 rounded-xl font-bold shadow-sm hover:bg-gray-50 transition">View History</button>
            <button id="save-finance-btn" class="bg-primary text-white px-8 py-2 rounded-xl font-bold shadow-lg hover:opacity-90 transition">Save Finance Data</button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Income Section -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
                <div class="flex items-center justify-between mb-8">
                    <h3 class="text-xl font-bold">Monthly Income</h3>
                    <div class="flex bg-gray-100 p-1 rounded-xl">
                        <button type="button" data-target="sunday-table-container" class="service-tab px-4 py-1.5 rounded-lg text-xs font-bold bg-white shadow-sm text-primary">Sunday</button>
                        <button type="button" data-target="weekday-table-container" class="service-tab px-4 py-1.5 rounded-lg text-xs font-bold text-gray-500 hover:text-primary transition">Weekday</button>
                        <button type="button" data-target="special-table-container" class="service-tab px-4 py-1.5 rounded-lg text-xs font-bold text-gray-500 hover:text-primary transition">Special</button>
                    </div>
                </div>

                <div class="overflow-x-auto tab-content block" id="sunday-table-container">
                    <table class="w-full text-left" data-service="sunday">
                        <thead>
                            <tr class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">
                                <th class="pb-4 px-2">Week</th>
                                <th class="pb-4 px-2">Tithes</th>
                                <th class="pb-4 px-2">Offering</th>
                                <th class="pb-4 px-2">Special</th>
                                <th class="pb-4 px-2">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            {{#each weeks}}
                            <tr class="income-row sunday-row" data-week="{{this.weekNumber}}">
                                <td class="py-5 px-2 font-bold text-sm text-gray-900">Week {{this.weekNumber}}</td>
                                <td class="py-5 px-2">
                                    <div class="relative">
                                        <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                                        <input type="number" step="0.01" class="tithe-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" data-service="sunday" data-week="{{this.weekNumber}}" value="{{this.sunday.tithes}}">
                                    </div>
                                </td>
                                <td class="py-5 px-2">
                                    <div class="relative">
                                        <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                                        <input type="number" step="0.01" class="offering-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" data-service="sunday" data-week="{{this.weekNumber}}" value="{{this.sunday.offering}}">
                                    </div>
                                </td>
                                <td class="py-5 px-2">
                                    <div class="relative">
                                        <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                                        <input type="number" step="0.01" class="special-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" data-service="sunday" data-week="{{this.weekNumber}}" value="{{this.sunday.specialCollection}}">
                                    </div>
                                </td>
                                <td class="py-5 px-2 font-bold text-gray-900 text-sm row-total">₦0.00</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                <div class="overflow-x-auto tab-content hidden" id="weekday-table-container">
                    <table class="w-full text-left" data-service="weekday">
                        <thead>
                            <tr class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">
                                <th class="pb-4 px-2">Week</th>
                                <th class="pb-4 px-2">Tithes</th>
                                <th class="pb-4 px-2">Offering</th>
                                <th class="pb-4 px-2">Special</th>
                                <th class="pb-4 px-2">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            {{#each weeks}}
                            <tr class="income-row weekday-row" data-week="{{this.weekNumber}}">
                                <td class="py-5 px-2 font-bold text-sm text-gray-900">Week {{this.weekNumber}}</td>
                                <td class="py-5 px-2">
                                    <div class="relative">
                                        <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                                        <input type="number" step="0.01" class="tithe-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" data-service="weekday" data-week="{{this.weekNumber}}" value="{{this.weekday.tithes}}">
                                    </div>
                                </td>
                                <td class="py-5 px-2">
                                    <div class="relative">
                                        <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                                        <input type="number" step="0.01" class="offering-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" data-service="weekday" data-week="{{this.weekNumber}}" value="{{this.weekday.offering}}">
                                    </div>
                                </td>
                                <td class="py-5 px-2">
                                    <div class="relative">
                                        <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                                        <input type="number" step="0.01" class="special-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" data-service="weekday" data-week="{{this.weekNumber}}" value="{{this.weekday.specialCollection}}">
                                    </div>
                                </td>
                                <td class="py-5 px-2 font-bold text-gray-900 text-sm row-total">₦0.00</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                <div class="overflow-x-auto tab-content hidden" id="special-table-container">
                    <table class="w-full text-left" data-service="special">
                        <thead>
                            <tr class="text-[10px] uppercase tracking-widest text-gray-400 font-bold">
                                <th class="pb-4 px-2">Week</th>
                                <th class="pb-4 px-2">Tithes</th>
                                <th class="pb-4 px-2">Offering</th>
                                <th class="pb-4 px-2">Special</th>
                                <th class="pb-4 px-2">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            {{#each weeks}}
                            <tr class="income-row special-row" data-week="{{this.weekNumber}}">
                                <td class="py-5 px-2 font-bold text-sm text-gray-900">Week {{this.weekNumber}}</td>
                                <td class="py-5 px-2">
                                    <div class="relative">
                                        <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                                        <input type="number" step="0.01" class="tithe-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" data-service="special" data-week="{{this.weekNumber}}" value="{{this.special.tithes}}">
                                    </div>
                                </td>
                                <td class="py-5 px-2">
                                    <div class="relative">
                                        <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                                        <input type="number" step="0.01" class="offering-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" data-service="special" data-week="{{this.weekNumber}}" value="{{this.special.offering}}">
                                    </div>
                                </td>
                                <td class="py-5 px-2">
                                    <div class="relative">
                                        <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                                        <input type="number" step="0.01" class="special-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" data-service="special" data-week="{{this.weekNumber}}" value="{{this.special.specialCollection}}">
                                    </div>
                                </td>
                                <td class="py-5 px-2 font-bold text-gray-900 text-sm row-total">₦0.00</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Expenditures Section -->
        <div class="space-y-6">
            <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
                <h3 class="text-xl font-bold mb-6">Expenditures</h3>
                <div class="space-y-4" id="expenditure-container">
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-gray-500 ml-1">Electricity & Power</label>
                        <div class="relative">
                            <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                            <input type="number" id="exp-electricity" class="exp-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" value="{{expenditures.expElectricity}}">
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-gray-500 ml-1">Stationery & Office</label>
                        <div class="relative">
                            <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                            <input type="number" id="exp-stationery" class="exp-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" value="{{expenditures.expStationery}}">
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-gray-500 ml-1">Pastor's Allowance</label>
                        <div class="relative">
                            <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                            <input type="number" id="exp-pastor" class="exp-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" value="{{expenditures.expPastor}}">
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-gray-500 ml-1">Welfare & Support</label>
                        <div class="relative">
                            <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                            <input type="number" id="exp-welfare" class="exp-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" value="{{expenditures.expWelfare}}">
                        </div>
                    </div>
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-gray-500 ml-1">Miscellaneous</label>
                        <div class="relative">
                            <span class="absolute left-3 top-2.5 text-gray-400 text-xs">₦</span>
                            <input type="number" id="exp-misc" class="exp-input w-full bg-gray-50 border-none rounded-xl pl-7 pr-3 py-2 text-sm focus:ring-1 focus:ring-primary transition" placeholder="0.00" value="{{expenditures.expMisc}}">
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t border-gray-50">
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-bold text-gray-400 uppercase tracking-widest">Total Exp.</span>
                        <span class="text-xl font-bold text-red-600" id="total-expenditure">₦0.00</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const incomeRows = document.querySelectorAll('.income-row');
        const expInputs = document.querySelectorAll('.exp-input');
        const totalExpSpan = document.getElementById('total-expenditure');

        const formatCurrency = (val) => {
            return '₦' + parseFloat(val || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        };

        const updateRowTotal = (row) => {
            const tithe = parseFloat(row.querySelector('.tithe-input').value) || 0;
            const offering = parseFloat(row.querySelector('.offering-input').value) || 0;
            const special = parseFloat(row.querySelector('.special-input').value) || 0;
            const total = tithe + offering + special;
            row.querySelector('.row-total').textContent = formatCurrency(total);
        };

        const updateGrandExpenditure = () => {
            let total = 0;
            expInputs.forEach(input => {
                total += parseFloat(input.value) || 0;
            });
            totalExpSpan.textContent = formatCurrency(total);
        };

        incomeRows.forEach(row => {
            updateRowTotal(row); // Initial call to calculate total from saved values
            row.querySelectorAll('input').forEach(input => {
                input.addEventListener('input', () => updateRowTotal(row));
            });
        });

        updateGrandExpenditure(); // Initial calculation of expenditure total
        expInputs.forEach(input => {
            input.addEventListener('input', updateGrandExpenditure);
        });

        // Service Tab Switching
        const serviceTabs = document.querySelectorAll('.service-tab');
        const tabContents = document.querySelectorAll('.tab-content');

        serviceTabs.forEach(tab => {
            tab.addEventListener('click', (e) => {
                e.preventDefault();
                
                serviceTabs.forEach(t => {
                    t.classList.remove('bg-white', 'shadow-sm', 'text-primary');
                    t.classList.add('text-gray-500');
                });
                
                tabContents.forEach(content => {
                    content.classList.remove('block');
                    content.classList.add('hidden');
                });
                
                tab.classList.remove('text-gray-500');
                tab.classList.add('bg-white', 'shadow-sm', 'text-primary');

                const targetId = tab.dataset.target;
                if (targetId) {
                    const targetContent = document.getElementById(targetId);
                    if (targetContent) {
                        targetContent.classList.remove('hidden');
                        targetContent.classList.add('block');
                    }
                }
            });
        });

        // Save Finance Data Button Event Listener
        const saveBtn = document.getElementById('save-finance-btn');
        if (saveBtn) {
            saveBtn.addEventListener('click', async (e) => {
                e.preventDefault();
                saveBtn.disabled = true;
                saveBtn.textContent = 'Saving...';

                try {
                    const monthVal = document.getElementById('finance-month').value;

                    // Serialize Sundays
                    const sundays = [];
                    document.querySelectorAll('.sunday-row').forEach(row => {
                        sundays.push({
                            weekNumber: row.dataset.week,
                            tithes: row.querySelector('.tithe-input').value,
                            offering: row.querySelector('.offering-input').value,
                            specialCollection: row.querySelector('.special-input').value
                        });
                    });

                    // Serialize Weekdays
                    const weekdays = [];
                    document.querySelectorAll('.weekday-row').forEach(row => {
                        weekdays.push({
                            weekNumber: row.dataset.week,
                            tithes: row.querySelector('.tithe-input').value,
                            offering: row.querySelector('.offering-input').value,
                            specialCollection: row.querySelector('.special-input').value
                        });
                    });

                    // Serialize Specials
                    const specials = [];
                    document.querySelectorAll('.special-row').forEach(row => {
                        specials.push({
                            weekNumber: row.dataset.week,
                            tithes: row.querySelector('.tithe-input').value,
                            offering: row.querySelector('.offering-input').value,
                            specialCollection: row.querySelector('.special-input').value
                        });
                    });

                    // Serialize Expenditures
                    const expenditures = {
                        expElectricity: document.getElementById('exp-electricity').value,
                        expStationery: document.getElementById('exp-stationery').value,
                        expPastor: document.getElementById('exp-pastor').value,
                        expWelfare: document.getElementById('exp-welfare').value,
                        expMisc: document.getElementById('exp-misc').value
                    };

                    const payload = {
                        month: monthVal,
                        sundays,
                        weekdays,
                        specials,
                        expenditures
                    };

                    const response = await fetch('/finance/save', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(payload)
                    });

                    const result = await response.json();
                    if (result.success) {
                        alert('Finance data saved successfully!');
                    } else {
                        alert('Error: ' + result.message);
                    }
                } catch (err) {
                    console.error(err);
                    alert('An error occurred while saving.');
                } finally {
                    saveBtn.disabled = false;
                    saveBtn.textContent = 'Save Finance Data';
                }
            });
        }
    });
</script>
