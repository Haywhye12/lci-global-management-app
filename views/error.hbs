<div class="max-w-md mx-auto my-12 bg-white rounded-3xl border border-gray-100 shadow-xl overflow-hidden p-8 md:p-10 text-center space-y-6">
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-50 text-red-500 mb-2">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
    </div>
    
    <div class="space-y-2">
        <h2 class="text-2xl font-bold text-gray-900 tracking-tight">An Error Occurred</h2>
        <p class="text-sm text-gray-500 font-medium">
            {{#if message}}
                {{message}}
            {{else}}
                Something went wrong. Please try again or contact support.
            {{/if}}
        </p>
    </div>

    <div class="pt-4 border-t border-gray-50 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="px-6 py-2.5 bg-primary text-white rounded-xl text-sm font-bold shadow-md hover:opacity-95 transition">
            Go to Dashboard
        </a>
        <button onclick="window.history.back()" class="px-6 py-2.5 bg-gray-50 border border-gray-100 text-gray-700 rounded-xl text-sm font-bold hover:bg-gray-100 transition">
            Go Back
        </button>
    </div>
</div>
